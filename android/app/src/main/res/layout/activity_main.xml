<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="32dp"
    android:gravity="center">
    <TextView android:text="Phone Screen Share" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textSize="24sp" android:textStyle="bold" android:layout_marginBottom="40dp"/>
    <EditText android:id="@+id/ipInput" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="PC IP e.g. 192.168.1.3" android:textSize="18sp" android:padding="14dp" android:layout_marginBottom="20dp"/>
    <Button android:id="@+id/startBtn" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Start Streaming" android:textSize="16sp" android:padding="14dp" android:layout_marginBottom="20dp"/>
    <TextView android:id="@+id/statusText" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Not connected" android:textSize="14sp"/>
</LinearLayout>
